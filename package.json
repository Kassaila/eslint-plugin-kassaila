{
  "name": "eslint-plugin-kassaila",
  "version": "0.1.0",
  "description": "Custom ESLint rules: jsdoc-comment-style, prefer-arrow-without-this, switch-case-braces",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "eslint .",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "eslint",
    "eslintplugin",
    "eslint-plugin",
    "jsdoc",
    "arrow-functions",
    "switch-case"
  ],
  "license": "MIT",
  "peerDependencies": {
    "eslint": "^9.0.0 || ^10.0.0"
  },
  "dependencies": {
    "@typescript-eslint/utils": "^8.57.2"
  },
  "devDependencies": {
    "@typescript-eslint/rule-tester": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "eslint": "^10.1.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.2"
  }
}
